SERVICE_NAME=cart-service
NODE_ENV=production
CART_PORT=3003

LOG_LEVEL=info
REQUEST_TIMEOUT_MS=5000
CORS_ORIGIN=https://your-domain.example

CART_MONGO_URI=mongodb+srv://cart_svc:password@cluster0.mongodb.net
CART_MONGO_DBNAME=cart_db

ACCESS_TOKEN=change_me_to_a_strong_secret
JWT_EXPIRES_IN=8h

PRODUCT_SERVICE_URL=http://product-service
PRODUCT_RETRY_COUNT=2
